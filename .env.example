# Roamin Ambient Agent — Environment Variables
# Copy this file to .env and fill in values as needed.
# Environment variables take precedence over .env values.

# --- Control API ---
# Optional API key for Control API authentication.
# If unset, API runs without authentication (local dev default).
# ROAMIN_CONTROL_API_KEY=your-secret-key-here

# --- Debug ---
# Set to any value to enable debug logging (WebSocket auth, model routing, etc.)
# ROAMIN_DEBUG=1

# --- LM Studio ---
# API token for authenticated LM Studio endpoints.
# Get from: LM Studio Settings -> Developer -> Core -> Authentication
# Also supports per-model override via "api_key_env" in model_config.json.
# LM_API_TOKEN=sk-lm-your-token-here

# --- Approval Gates ---
# Set to 1 to skip approval prompts for high-risk tools (dev/testing only).
# ROAMIN_SKIP_APPROVAL=1
