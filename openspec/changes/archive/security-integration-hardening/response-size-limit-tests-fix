### Step 2: Update Test Code with Custom Mock

**Create custom mock class that doesn't require importing `requests`:**

Edit `tests/test_model_router.py`, lines 74-82 (replace `_force_http_path` method):

```python
# Replace this:

def _force_http_path(self, router, mock_post):
    """Context stack that routes respond() to the mocked HTTP endpoint."""
    return (
        patch.object(router, "select", return_value={}),
        patch.object(router, "endpoint", return_value="http://127.0.0.1:1234"),
        patch.object(router, "model_id", return_value="test-model"),
        patch("requests.post", return_value=mock_post),
    )

# With this:

class _MockHTTPResponse:
    """Mock HTTP response for testing without requiring requests module."""

    def __init__(self, content, status=200):
        self.content = content if isinstance(content, bytes) else json.dumps(content).encode('utf-8')
        self.status = status
        self.text = json.dumps(content) if not isinstance(content, bytes) else content.decode('utf-8') if len(content) > 0 else "{}"

    def raise_for_status(self):
        pass  # Don't raise any exceptions

    def json(self):
        return json.loads(json.dumps({"response": "mock response"}) if isinstance(self.content, str) else self.content.decode('utf-8') if self.content and len(self.content) > 0 else "{}")

# Replace _force_http_path with this:
def _force_http_path(self, router, mock_resp):
    """Context stack that routes respond() to the mocked HTTP endpoint.

    Uses custom mock to avoid importing 'requests' module during patch setup.
    """
    # Use lambda to create mock response without importing requests
    def _mock_requests_post(*args, **kwargs):
        return _MockHTTPResponse(kwargs.get('json', {}))

    return (
        patch.object(router, "select", return_value={}),
        patch.object(router, "endpoint", return_value="http://127.0.0.1:1234"),
        patch.object(router, "model_id", return_value="test-model"),
        patch("requests.post", side_effect=_mock_requests_post),  # Use lambda to avoid import during setup
    )

# Update test methods to use _MockHTTPResponse instances directly

